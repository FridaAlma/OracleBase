# ── Model connection ──────────────────────────────────────────────
# Any OpenAI-compatible API provider
API_BASE_URL=https://api.deepseek.com
API_KEY=your-api-key-here

# ── Model IDs ─────────────────────────────────────────────────────
MODEL_ID=deepseek-v4-flash        # Fast/cheap model
MODEL_PRO_ID=deepseek-v4-pro      # High-quality model
MODEL_TIER=auto                   # auto | flash | pro

# ── Model parameters ──────────────────────────────────────────────
MAX_TOKENS=16384
REQUEST_TIMEOUT=300
TEMPERATURE=0.1
MAX_RETRIES=5

# ── Display info (opzionale, usato dall'endpoint /api/model) ──────
MODEL_NAME=DeepSeek V4 Flash
MODEL_PRO_NAME=DeepSeek V4 Pro

# ── Server configuration ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
